// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "collaboration_panel": {
    "dock": "left"
  },
  "helix_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "diff_view_style": "unified",
  "vim_mode": false,
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    },
    "github-copilot": {
      "type": "registry"
    }
  },
  "scroll_sensitivity": 4.0,
  "sticky_scroll": {
    "enabled": false
  },
  "window_decorations": "client",
  "excerpt_context_lines": 2,
  "show_wrap_guides": true,
  "git_panel": {
    "dock": "left",
    "collapse_untracked_diff": false,
    "tree_view": true,
    "sort_by_path": true,
    "default_width": 420.0,
  },
  "theme": "Rosé Pine Moon",
  "theme_overrides": {
    "Moonlight": {
      "created": "#00ff00",
      "created.background": "#22c55e",
      "modified": "#ffa500",
      "modified.background": "#ffa500",
      "deleted": "#ef4444",
      "deleted.background": "#ef4444",
      "syntax": {
        "property": {
          "color": "#e06c75",
        },
        "attribute": {
          "color": "#ff9e64",
        },
      },
    },
  },
  "agent": {
    "dock": "right",
    "single_file_review": true,
    "default_profile": "ask",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "gemini-3.1-pro-preview",
    },
    "model_parameters": [],
  },
  "expand_excerpt_lines": 5,
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "active_pane_modifiers": {
    "border_size": 0.0,
    "inactive_opacity": 1.0,
  },
  "centered_layout": {
    "right_padding": 0.2,
    "left_padding": 0.2,
  },
  "horizontal_scroll_margin": 0.0,
  "audio": {
    "experimental.auto_microphone_volume": true,
    "experimental.rodio_audio": true,
    "experimental.legacy_audio_compatible": true,
    "experimental.denoise": true,
    "experimental.auto_speaker_volume": true,
  },
  "colorize_brackets": true,
  "indent_guides": {
    "coloring": "indent_aware",
    "background_coloring": "disabled",
  },
  "use_system_window_tabs": false,
  "cursor_shape": "bar",
  "multi_cursor_modifier": "alt",
  "edit_predictions": {
    "copilot": {
      "enable_next_edit_suggestions": true
    },
    "provider": "zed",
    "disabled_globs": [],
    "mode": "subtle",
  },
  "show_edit_predictions": true,
  "zoomed_padding": true,
  "current_line_highlight": "all",
  "selection_highlight": true,
  "rounded_selection": true,
  "buffer_line_height": "comfortable",
  "calls": {
    "mute_on_join": false,
  },
  "show_signature_help_after_edits": false,
  "completions": {
    "words_min_length": 2,
    "words": "enabled",
  },
  "completion_menu_scrollbar": "system",
  "outline_panel": {
    "dock": "left",
    "expand_outlines_with_depth": 100,
    "default_width": 300.0,
    "git_status": true,
    "button": true,
  },
  "bottom_dock_layout": "contained",
  "preview_tabs": {
    "enabled": true,
    "enable_keep_preview_on_code_navigation": false,
    "enable_preview_from_file_finder": false,
  },
  "tabs": {
    "show_close_button": "hover",
    "show_diagnostics": "off",
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_project_items": true,
    "show_sign_in": true,
    "show_user_picture": true,
    "show_onboarding_banner": true,
    "show_menus": false,
    "show_branch_icon": true,
  },
  "project_panel": {
    "indent_size": 20.0,
    "default_width": 240.0,
    "sort_mode": "directories_first",
    "entry_spacing": "comfortable",
    "auto_fold_dirs": true,
    "starts_open": true,
    "auto_reveal_entries": true,
    "git_status": true,
    "dock": "right",
    "button": true,
  },
  "hard_tabs": false,
  "toolbar": {
    "code_actions": false,
    "agent_review": true,
    "selections_menu": true,
    "quick_actions": true,
    "breadcrumbs": true,
  },
  "scrollbar": {
    "diagnostics": "all",
    "show": "auto",
    "selected_symbol": true,
    "axes": {
      "vertical": true,
      "horizontal": true,
    },
    "selected_text": true,
    "search_results": true,
    "cursors": true,
    "git_diff": true,
  },
  "relative_line_numbers": "disabled",
  "gutter": {
    "line_numbers": true,
  },
  "tab_bar": {
    "show_nav_history_buttons": true,
    "show": true,
  },
  "debugger": {
    "dock": "bottom",
    "stepping_granularity": "line",
    "button": true,
  },
  "search": {
    "whole_word": false,
    "button": true,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
    "button": true,
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "padding": 0,
      "show_commit_summary": false,
    },
    "hunk_style": "staged_hollow",
  },
  "minimap": {
    "display_in": "all_editors",
    "max_width_columns": 90,
    "thumb": "hover",
  },
  "fast_scroll_sensitivity": 2.0,
  "vertical_scroll_margin": 6.0,
  "prettier": {
    "allowed": true,
  },
  "file_finder": {
    "git_status": true,
  },
  "terminal": {
    "working_directory": "current_project_directory",
    "default_height": 320.0,
    "default_width": 640.0,
    "font_size": 15.0,
    "button": true,
    "cursor_shape": "bar",
  },
  "auto_update": true,
  "icon_theme": "Material Icon Theme",
  "inlay_hints": {
    "enabled": true,
    "show_value_hints": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
    "toggle_on_modifiers_press": {
      "control": false,
      "alt": false,
      "shift": false,
      "platform": false,
      "function": false,
    },
  },
  "file_types": {
    "Helm": [
      "**/templates/**/*.tpl",
      "**/templates/**/*.yaml",
      "**/templates/**/*.yml",
      "**/helmfile.d/**/*.yaml",
      "**/helmfile.d/**/*.yml",
    ],
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "load_direnv": "shell_hook",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "disable_ai": false,
  "lsp": {
    "deno": {
      "settings": {
        "deno": {
          "enable": true,
        },
      },
    },
  },
  "languages": {
    "JavaScript": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint",
        "tailwindcss-language-server",
      ],
      "formatter": [{ "language_server": { "name": "deno" } }],
    },
    "TSX": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint",
        "tailwindcss-language-server",
      ],
      "formatter": [{ "language_server": { "name": "deno" } }],
      "inlay_hints": {
        "enabled": true,
        "show_type_hints": false,
      },
      "tab_size": 2,
    },
    "TypeScript": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint",
        "tailwindcss-language-server",
      ],
      "formatter": [{ "language_server": { "name": "deno" } }],
      "inlay_hints": {
        "enabled": true,
        "show_type_hints": false,
      },
      "tab_size": 2,
    },
    "Python": {
      "language_servers": [
        "ruff",
        "!basedpyright",
        "!pyright",
        "ty",
        "!pyrefly",
      ],
      "format_on_save": "on",
      "formatter": [{ "language_server": { "name": "ruff" } }],
    },
    "Rust": {
      "formatter": "language_server",
    },
  },
}
